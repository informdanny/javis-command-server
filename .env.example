AGENT_API_KEY=dev-local-key
SERVICE_NAME=javis-command-server
LOG_LEVEL=INFO
DUPLICATE_TTL_SECONDS=60

# Voice provider selection
DEFAULT_VOICE_PROVIDER=xai
VOICE_SYSTEM_PROMPT=You are Jarvis, a concise voice assistant for a home device.
REALTIME_AUDIO_SAMPLE_RATE=16000
WEB_SEARCH_TIMEOUT_SECONDS=8.0
WEB_SEARCH_MAX_RESULTS=3

# OpenAI realtime A/B lane
OPENAI_API_KEY=
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_VOICE=cedar
OPENAI_TURN_DETECTION_TYPE=semantic_vad
OPENAI_SEMANTIC_VAD_EAGERNESS=auto

# xAI realtime + always-on STT lane
XAI_API_KEY=
XAI_REALTIME_URL=wss://api.x.ai/v1/realtime
XAI_STT_URL=https://api.x.ai/v1/stt
XAI_VOICE=ara
XAI_VAD_THRESHOLD=0.85
XAI_VAD_SILENCE_DURATION_MS=700
XAI_VAD_PREFIX_PADDING_MS=333
